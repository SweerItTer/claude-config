{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "skillListingBudgetFraction": 0.01,
  "env": {
    "CLAUDE_CODE_ATTRIBUTION_HEADER": "0",
    "CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NEW_INIT": "1",
    "CTX_STRICT_BASH": "0",
    "DISABLE_AUTOUPDATER": "1",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "skillOverrides": {
    "claude-code-setup:claude-automation-recommender": "name-only",
    "code-review:code-review": "name-only",
    "context-mode:context-mode": "on",
    "context-mode:context-mode-ops": "on",
    "context-mode:ctx-doctor": "on",
    "context-mode:ctx-purge": "on",
    "context-mode:ctx-stats": "on",
    "context-mode:ctx-upgrade": "on",
    "feature-dev:feature-dev": "name-only",
    "skill-creator:skill-creator": "name-only",
    "superpowers:brainstorm": "on",
    "superpowers:brainstorming": "on",
    "superpowers:dispatching-parallel-agents": "on",
    "superpowers:execute-plan": "on",
    "superpowers:executing-plans": "on",
    "superpowers:finishing-a-development-branch": "on",
    "superpowers:receiving-code-review": "on",
    "superpowers:requesting-code-review": "on",
    "superpowers:subagent-driven-development": "on",
    "superpowers:systematic-debugging": "on",
    "superpowers:test-driven-development": "on",
    "superpowers:using-git-worktrees": "on",
    "superpowers:using-superpowers": "on",
    "superpowers:verification-before-completion": "on",
    "superpowers:write-plan": "on",
    "superpowers:writing-plans": "on",
    "superpowers:writing-skills": "on",
    "update-config": "on",
    "using-superpowers": "on"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_CONFIG_DIR:-$HOME/.claude}/plugins/marketplaces/context-mode/hooks/posttooluse.mjs"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "WebFetch|Read|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_CONFIG_DIR:-$HOME/.claude}/plugins/marketplaces/context-mode/hooks/pretooluse.mjs"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/rtk-rewrite.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/rules-loader.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/context-mode-cache-heal.mjs && openspec init --tools claude"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node ${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hud/omc-hud.mjs"
  },
  "enabledPlugins": {
    "claude-code-setup@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "context-mode@context-mode": true,
    "feature-dev@claude-plugins-official": true,
    "oh-my-claudecode@omc": true,
    "skill-creator@claude-plugins-official": true,
    "superpowers@superpowers": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    },
    "ecc": {
      "source": {
        "source": "github",
        "repo": "affaan-m/everything-claude-code"
      }
    },
    "omc": {
      "source": {
        "source": "git",
        "url": "https://github.com/Yeachan-Heo/oh-my-claudecode.git"
      }
    },
    "superpowers": {
      "source": {
        "source": "git",
        "url": "https://github.com/obra/superpowers.git"
      }
    }
  },
  "language": "简体中文",
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "disabledMcpServers": [
    "browser-use",
    "browserbase",
    "clickhouse",
    "cloudflare-docs",
    "cloudflare-observability",
    "cloudflare-workers-bindings",
    "cloudflare-workers-builds",
    "confluence",
    "devfleet",
    "evalview",
    "fal-ai",
    "jira",
    "laraplugins",
    "longhand",
    "magic",
    "omega-memory",
    "railway",
    "supabase",
    "token-optimizer",
    "vercel"
  ],
  "maxSkillDescriptionChars": 64,
  "think": false
}
